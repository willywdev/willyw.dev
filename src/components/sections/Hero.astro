---
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import { getLangFromUrl, useTranslations } from "../../i18n/utils.js";
import avatar from "../../assets/avatar.png";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const roles = {
  de: ["Technical_Lead", "JavaScript-Experte", "Geo-Tüftler", "Problemlöser"],
  en: ["Technical_Lead", "JavaScript_expert", "Geo_tinkerer", "Problem_solver"],
};
---

<section
  class="relative overflow-hidden px-6 pb-20 pt-[5.5rem] text-center sm:px-8"
>
  <div class="glow" aria-hidden="true"></div>

  <div class="relative z-10 mx-auto max-w-3xl">
    <div class="avatar-wrap mx-auto mb-7 w-fit">
      <Image
        src={avatar}
        alt="Wilhelm Werwein"
        width={208}
        height={208}
        loading="eager"
        class="avatar size-[104px] rounded-full object-cover"
      />
    </div>
    <p class="mb-5 font-mono text-[14px] text-accent">
      <span class="text-overlay1">/home/</span><span id="role-rotator" data-roles={JSON.stringify(roles[lang])}>{roles[lang][0]}</span><span class="role-caret">▋</span>
    </p>

    <h1
      class="text-balance text-[clamp(40px,7vw,68px)] font-extrabold leading-[1.03] tracking-tight text-white"
    >
      Wilhelm&nbsp;Werwein
    </h1>

    <p
      class="mx-auto mt-5 max-w-[50ch] text-[clamp(16px,1.7vw,19px)] text-subtext0"
    >
      {t("hero.sub")}
    </p>

    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a
        href="#projekte"
        class="inline-flex items-center gap-2 rounded-[10px] bg-accent-strong px-5 py-3 text-[15px] font-medium text-white transition-colors hover:brightness-110"
      >
        {t("hero.cta.projects")}
        <Icon name="lucide:arrow-right" class="size-[18px]" />
      </a>
      <a
        href="#ueber"
        class="inline-flex items-center gap-2 rounded-[10px] border border-surface1 px-5 py-3 text-[15px] font-medium text-text transition-colors hover:border-overlay1 hover:text-white"
      >
        {t("hero.cta.about")}
      </a>
    </div>
  </div>
</section>

<style>
  .glow {
    position: absolute;
    top: -34%;
    left: 50%;
    width: 760px;
    height: 560px;
    max-width: 120vw;
    transform: translateX(-50%) translateZ(0);
    will-change: transform, opacity;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.3;
    z-index: 0;
    background:
      radial-gradient(circle at 50% 50%, var(--color-accent), transparent 60%),
      radial-gradient(circle at 30% 62%, var(--color-teal), transparent 55%),
      radial-gradient(circle at 70% 38%, var(--color-accent-warm), transparent 50%);
  }

  @media (max-width: 640px) {
    .glow {
      width: 460px;
      height: 380px;
      filter: blur(48px);
    }
  }

  .avatar {
    box-shadow:
      0 0 0 2px color-mix(in oklab, var(--color-accent-warm) 75%, transparent),
      0 0 0 7px color-mix(in oklab, var(--color-accent-warm) 12%, transparent),
      0 16px 40px -14px rgba(0, 0, 0, 0.65);
  }

  .role-caret { color: var(--color-accent); }

  @media (prefers-reduced-motion: no-preference) {
    .role-caret { animation: role-blink 1.1s steps(2, end) infinite; }
    .glow { animation: glow-drift 22s ease-in-out infinite alternate; }
    .avatar-wrap { animation: avatar-float 6.5s ease-in-out infinite; }
  }

  @keyframes role-blink { 50% { opacity: 0; } }

  @keyframes glow-drift {
    from { transform: translateX(-50%) translateY(0) scale(1); opacity: 0.26; }
    to   { transform: translateX(-46%) translateY(8px) scale(1.07); opacity: 0.36; }
  }

  @keyframes avatar-float {
    50% { transform: translateY(-7px); }
  }
</style>

<script>
  /** @type {ReturnType<typeof setTimeout> | null} */
  let rotatorTimer = null;

  function initRotator() {
    const el = document.getElementById("role-rotator");
    if (!el) return;

    if (rotatorTimer !== null) {
      clearTimeout(rotatorTimer);
      rotatorTimer = null;
    }

    const roles = JSON.parse(el.dataset.roles);
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (!reduce && roles.length > 1) {
      let i = 0, j = roles[0].length, deleting = true;
      function tick() {
        const word = roles[i];
        if (deleting) j--; else j++;
        el.textContent = word.slice(0, j);
        let delay = deleting ? 38 : 70;
        if (!deleting && j === word.length) { deleting = true; delay = 1500; }
        else if (deleting && j === 0) { deleting = false; i = (i + 1) % roles.length; delay = 320; }
        rotatorTimer = setTimeout(tick, delay);
      }
      rotatorTimer = setTimeout(tick, 1500);
    }
  }

  document.addEventListener("astro:page-load", initRotator);
</script>
