---
import { Icon } from "astro-icon/components";
import SectionLabel from "../SectionLabel.astro";
import { projects } from "../../data/projects.js";
import { getLangFromUrl, useTranslations } from "../../i18n/utils.js";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="projekte" class="reveal border-t border-surface0/50 py-15 bg-mantle">
  <div class="mx-auto max-w-5xl px-6 sm:px-8">
    <SectionLabel num="03" text={t("projects.label")} />
    <h2 class="mb-5 text-[30px] font-bold tracking-tight text-white">
      {t("projects.heading")}
    </h2>

    <ul class="grid gap-[18px] sm:grid-cols-2">
      {
        projects.map((project) => {
          const isPlaceholder = project.href === "#";
          return (
            <li>
              {isPlaceholder ? (
                <div class="block h-full rounded-2xl border border-dashed border-surface0 bg-mantle p-[22px] opacity-60">
                  <div class="mb-3.5 flex items-center justify-between">
                    <span class="grid size-[42px] place-items-center rounded-[10px] bg-surface0/40 text-overlay1">
                      <Icon name={project.icon} class="size-[22px]" />
                    </span>
                  </div>
                  <h3 class="text-[19px] font-semibold tracking-tight text-white">
                    {project.title[lang]}
                  </h3>
                  <p class="mt-1.5 text-[14.5px] text-subtext0">
                    {project.description[lang]}
                  </p>
                  <div class="mt-4 flex flex-wrap gap-1.5">
                    {project.tags.map((tag) => (
                      <span class="rounded-md border border-surface0 bg-bg px-2 py-0.5 font-mono text-[11.5px] text-subtext0">
                        {tag}
                      </span>
                    ))}
                  </div>
                </div>
              ) : (
                <a
                  href={project.href}
                  target={project.href.startsWith("http") ? "_blank" : undefined}
                  rel={project.href.startsWith("http") ? "noopener noreferrer" : undefined}
                  class="group block h-full rounded-2xl border border-surface0 bg-mantle p-[22px] transition-all duration-200 hover:-translate-y-1 hover:border-accent"
                >
                  <div class="mb-3.5 flex items-center justify-between">
                    <span class="grid size-[42px] place-items-center rounded-[10px] bg-accent/12 text-accent">
                      <Icon name={project.icon} class="size-[22px]" />
                    </span>
                    <Icon
                      name="lucide:arrow-up-right"
                      class="size-5 text-overlay1 transition-colors group-hover:text-accent"
                    />
                  </div>
                  <h3 class="text-[19px] font-semibold tracking-tight text-white">
                    {project.title[lang]}
                  </h3>
                  <p class="mt-1.5 text-[14.5px] text-subtext0">
                    {project.description[lang]}
                  </p>
                  <div class="mt-4 flex flex-wrap gap-1.5">
                    {project.tags.map((tag) => (
                      <span class="rounded-md border border-surface0 bg-bg px-2 py-0.5 font-mono text-[11.5px] text-subtext0">
                        {tag}
                      </span>
                    ))}
                  </div>
                </a>
              )}
            </li>
          );
        })
      }
    </ul>
  </div>
</section>
