---
import { Icon } from "astro-icon/components";
import SectionLabel from "../SectionLabel.astro";
import { site } from "../../data/site.js";
import { getLangFromUrl, useTranslations } from "../../i18n/utils.js";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const links = [
  { icon: "lucide:mail", href: `mailto:${site.email}`, label: t("contact.aria.email") },
  { icon: "simple-icons:github", href: site.social.github, label: t("contact.aria.github") },
];
---

<section id="kontakt" class="reveal border-t border-surface0/50 py-15 text-center">
  <div class="mx-auto max-w-5xl px-6 sm:px-8">
    <SectionLabel num="04" text={t("contact.label")} />
    <h2 class="text-[clamp(28px,4vw,44px)] font-bold tracking-tight text-white">
      {t("contact.heading.pre")} <span class="text-accent">{t("contact.heading.accent")}</span>.
    </h2>

    <ul class="mt-7 flex justify-center gap-3.5">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              aria-label={link.label}
              class="grid size-[46px] place-items-center rounded-xl border border-surface0 bg-mantle text-subtext1 transition-colors hover:border-accent hover:text-white"
            >
              <Icon name={link.icon} class="size-[22px]" />
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>
