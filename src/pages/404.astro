---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { ui } from "../i18n/ui.js";
---

<BaseLayout title="404 — Wilhelm Werwein" description="Seite nicht gefunden — willyw.dev." noindex={true}>
  <Nav />
  <main>
    <section class="relative overflow-hidden px-6 pb-20 pt-[5.5rem] text-center sm:px-8">
      <div class="glow" aria-hidden="true"></div>
      <div class="relative mx-auto max-w-3xl">
        <p class="mb-4 font-mono text-[13px] text-accent-2">// 404</p>
        <p class="mb-4 font-extrabold leading-none tracking-tight text-white" style="font-size: clamp(80px, 18vw, 160px);" aria-hidden="true">
          404
        </p>
        <h1
          id="nf-heading"
          class="text-balance text-[clamp(24px,4vw,36px)] font-bold tracking-tight text-white"
          data-en={ui.en["notfound.heading"]}
        >
          {ui.de["notfound.heading"]}
        </h1>
        <p
          id="nf-text"
          class="mx-auto mt-4 max-w-[48ch] text-[clamp(15px,1.5vw,17px)] text-subtext0"
          data-en={ui.en["notfound.text"]}
        >
          {ui.de["notfound.text"]}
        </p>
        <div class="mt-8">
          <a
            id="nf-cta"
            href="/"
            data-en-href="/en/"
            data-en={ui.en["notfound.cta"]}
            class="inline-flex items-center gap-2 rounded-[10px] bg-accent-strong px-5 py-3 text-[15px] font-medium text-white transition-colors hover:brightness-110"
          >
            {ui.de["notfound.cta"]}
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script is:inline>
  try {
    var isEn = location.pathname.startsWith("/en/") || location.pathname === "/en";
    var stored = localStorage.getItem("lang");
    if (isEn || stored === "en") {
      document.documentElement.lang = "en";
      document.querySelectorAll("[data-en]").forEach(function(el) {
        el.textContent = el.dataset.en;
      });
      var cta = document.getElementById("nf-cta");
      if (cta && cta.dataset.enHref) cta.href = cta.dataset.enHref;
    }
  } catch (_) {}
</script>

<style>
  .glow {
    position: absolute;
    top: -34%;
    left: 50%;
    width: 760px;
    height: 560px;
    max-width: 120vw;
    transform: translateX(-50%) translateZ(0);
    will-change: transform;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.3;
    background:
      radial-gradient(circle at 50% 50%, var(--color-mauve), transparent 60%),
      radial-gradient(circle at 32% 60%, var(--color-teal), transparent 55%);
  }

  @media (max-width: 640px) {
    .glow {
      width: 460px;
      height: 380px;
      filter: blur(48px);
    }
  }
</style>
